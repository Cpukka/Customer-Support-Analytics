{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/CustomerSupportAPI/Dockerfile",
    "context": "backend/CustomerSupportAPI"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  },
  "services": {
    "backend": {
      "source": "backend/CustomerSupportAPI",
      "type": "web",
      "healthcheckPath": "/health",
      "healthcheckTimeout": 100,
      "startCommand": "dotnet CustomerSupportAPI.dll --urls http://0.0.0.0:$PORT"
    },
    "frontend": {
      "source": "frontend",
      "type": "web",
      "build": {
        "dockerfilePath": "frontend/Dockerfile"
      }
    },
    "aiservice": {
      "source": "ai-service",
      "type": "web",
      "build": {
        "dockerfilePath": "ai-service/Dockerfile"
      }
    }
  }
}