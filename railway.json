{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "backend": {
      "source": "backend/CustomerSupportAPI",
      "type": "web",
      "healthcheckPath": "/health",
      "healthcheckTimeout": 100
    },
    "frontend": {
      "source": "frontend",
      "type": "web",
      "startCommand": "npm start"
    },
    "aiservice": {
      "source": "ai-service",
      "type": "web",
      "healthcheckPath": "/health",
      "healthcheckTimeout": 100
    }
  }
}